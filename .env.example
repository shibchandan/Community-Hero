GEMINI_API_KEY=your_gemini_api_key_here
# Firebase Admin SDK credentials path or base64 string
FIREBASE_SERVICE_ACCOUNT_KEY=./firebase-admin-key.json

# Transactional Email Service (Brevo - HTTP API or SMTP Relay)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=no-reply@civichero.org
BREVO_SENDER_NAME=CivicHero Support

# Optional SMTP Relay config (if using SMTP instead of HTTP API)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=af44cc001@smtp-brevo.com
SMTP_PASS=your_brevo_api_key_here

# Security Secret for Session Cryptography
JWT_SECRET=generate_a_secure_long_random_string_here
